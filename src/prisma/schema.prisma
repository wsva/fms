generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- auth

model oauth2_token {
  access_token  String  @id @db.VarChar(1000)
  refresh_token String  @db.VarChar(1000)
  client_id     String  @db.VarChar(100)
  user_id       String  @db.VarChar(100)
  ip            String  @db.VarChar(100)
  parent        String? @db.VarChar(1000)
}

model oauth2_user {
  user_id      String  @id @db.VarChar(100)
  nickname     String? @db.VarChar(100)
  username     String? @db.VarChar(100)
  number       String? @db.VarChar(100)
  email        String  @db.VarChar(100)
  password     String  @db.VarChar(100)
  is_superuser String  @db.VarChar(1)
  is_staff     String  @db.VarChar(1)
  is_active    String  @db.VarChar(1)
}

// ---------- settings

model settings_api_key {
  uuid       String   @id @db.VarChar(100)
  user_id    String   @db.VarChar(100)
  name       String   @db.VarChar(100)
  key_hash   String   @unique @db.VarChar(64)
  created_at DateTime @default(now()) @db.Timestamptz(6)
}

// ---------- plan

model plan_plan {
  uuid       String   @id @db.VarChar(100)
  user_id    String   @db.VarChar(100)
  content    String
  minutes    Int
  favorite   String?  @db.VarChar(1)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model plan_record {
  uuid       String    @id @db.VarChar(100)
  user_id    String    @db.VarChar(100)
  plan_uuid  String    @db.VarChar(100)
  start_at   DateTime? @db.Timestamptz(6)
  status     String    @db.VarChar(100)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @db.Timestamptz(6)
}

// ---------- word

model dict_de {
  uuid String @id @db.VarChar(255)
  url  String @db.VarChar(255)
}

model dict_de_level {
  id       Int    @id @default(autoincrement())
  lemma    String @db.VarChar(255)
  pos      String @db.VarChar(100)
  articles String @db.VarChar(10)
  level    String @db.VarChar(10)
  url      String @db.VarChar(255)
}

model dict_en {
  id        Int    @id @default(autoincrement())
  headword  String @db.VarChar(255)
  pos       String @db.VarChar(100)
  level     String @db.VarChar(10)
  inventory String @db.VarChar(255)
  notes     String
}

model topword_de {
  id        Int     @id
  word      String
  freq      Int
  examples  Int?
  in_dict   String? @db.VarChar(1)
  base_form String?
  article   String? @db.VarChar(100)
  level     String? @db.VarChar(10)
}

model topword_de_example {
  id      Int    @id @default(autoincrement())
  word_id Int?
  example String
}

model word_trash {
  uuid       String   @id @db.VarChar(100)
  word       String
  created_by String
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

// ---------- blog

model blog {
  uuid        String   @id @db.VarChar(100)
  user_id     String   @db.VarChar(255)
  title       String   @db.VarChar(255)
  description String   @db.VarChar(255)
  content     String
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
}

// ---------- listen

model listen_media {
  uuid       String   @id @db.VarChar(100)
  user_id    String   @db.VarChar(100)
  title      String
  source     String
  note       String
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model listen_media_tag {
  uuid       String   @id @db.VarChar(100)
  media_uuid String   @db.VarChar(100)
  tag_uuid   String   @db.VarChar(100)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model listen_note {
  uuid       String   @id @db.VarChar(100)
  user_id    String   @db.VarChar(100)
  media_uuid String   @db.VarChar(100)
  note       String
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model listen_subtitle {
  uuid       String   @id @db.VarChar(100)
  user_id    String   @db.VarChar(100)
  media_uuid String   @db.VarChar(100)
  language   String   @db.VarChar(10)
  subtitle   String
  format     String   @db.VarChar(10)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model listen_tag {
  uuid        String   @id @db.VarChar(100)
  user_id     String   @db.VarChar(100)
  tag         String
  description String
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
}

model listen_transcript {
  uuid       String   @id @db.VarChar(100)
  user_id    String   @db.VarChar(100)
  media_uuid String   @db.VarChar(100)
  language   String   @db.VarChar(10)
  transcript String
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

// ---------- speak

model practice_text {
  uuid       String   @id @db.VarChar(100)
  user_id    String   @db.VarChar(100)
  text       String
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model practice_audio {
  uuid       String   @id @db.VarChar(100)
  user_id    String   @db.VarChar(100)
  text_uuid  String   @db.VarChar(100)
  audio_path String?
  recognized String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model ask_question {
  uuid       String   @id @db.VarChar(100)
  user_id    String   @db.VarChar(100)
  title      String?
  audio_path String?
  video_path String?
  content    String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model ask_answer {
  uuid          String   @id @db.VarChar(100)
  user_id       String   @db.VarChar(100)
  question_uuid String   @db.VarChar(100)
  audio_path    String?
  video_path    String?
  content       String?
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @default(now()) @db.Timestamptz(6)
}

model book_meta {
  uuid        String   @id @db.VarChar(100)
  user_id     String   @db.VarChar(100)
  title       String
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
}

model book_chapter {
  uuid        String   @id @db.VarChar(100)
  book_uuid   String   @db.VarChar(100)
  parent_uuid String?  @db.VarChar(100)
  order_num   Int
  title       String
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
}

model book_sentence {
  uuid          String   @id @db.VarChar(100)
  chapter_uuid  String   @db.VarChar(100)
  user_id       String   @db.VarChar(100)
  order_num     Int
  content       String
  sentence_type String   @db.VarChar(20)
  audio_path    String?
  recognized    String?
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @default(now()) @db.Timestamptz(6)
}

// ---------- card

model qsa_card {
  uuid        String   @id @db.VarChar(100)
  user_id     String   @db.VarChar(100)
  question    String
  suggestion  String
  answer      String
  familiarity Int
  note        String
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
}

model qsa_card_review {
  uuid           String   @id @db.VarChar(100)
  user_id        String   @db.VarChar(255)
  card_uuid      String   @db.VarChar(100)
  familiarity    Int
  interval_days  Int
  ease_factor    Int
  repetitions    Int
  last_review_at DateTime @db.Timestamptz(6)
  next_review_at DateTime @db.Timestamptz(6)
}

model qsa_card_tag {
  uuid       String   @id @db.VarChar(100)
  card_uuid  String   @db.VarChar(100)
  tag_uuid   String   @db.VarChar(100)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model qsa_tag {
  uuid        String   @id @db.VarChar(100)
  user_id     String   @db.VarChar(100)
  tag         String
  description String
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
}

